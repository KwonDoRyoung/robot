<launch>
    <!--
        복도 주행 정책 노드 실행

        시나리오 1 (고정 장애물 서행):
          danger_zone_y 에 위험 구간의 y 범위를 [y_min, y_max] 형식으로 설정
          예: 복도 y = 5.0 ~ 15.0 구간이 위험 → danger_zone_y: [5.0, 15.0]

        시나리오 2 (사람 회피):
          approach_vel_thresh, approach_dist_thresh 로 감도 조정
    -->

    <node pkg="onboard_detector_python"
          type="corridor_policy_node.py"
          name="corridor_policy_node"
          output="screen"
          launch-prefix="$(find onboard_detector_python)/.env/bin/python3">

        <!-- 속도 파라미터 -->
        <param name="normal_speed"          value="0.6" />
        <param name="lateral_speed"         value="0.2" />

        <!-- 접근 판정 -->
        <param name="approach_vel_thresh"   value="0.15" />
        <param name="approach_dist_thresh"  value="3.0"  />

        <!-- 정책 실행 주기 -->
        <param name="policy_rate"           value="20.0" />

    </node>
</launch>
