<?xml version="1.0"?>
<!--
  hdl_localization.launch (robot_slam wrapper)
  Improved from original with:
  - DIRECT7 (stable) vs DIRECT1 (unstable)
  - IMU enabled for rotation correction
  - Odometry prediction enabled
  - Finer NDT resolution (0.5m)
-->
<launch>
  <arg name="map_pcd"      default="$(find fast_lio)/PCD/scans.pcd" />
  <arg name="points_topic" default="/livox/lidar_filtered" />
  <arg name="imu_topic"    default="/imu/data" />
  <arg name="use_imu"      default="true" />
  <arg name="use_global_localization" default="true" />
  <arg name="odom_child_frame_id" default="base_footprint" />
  <arg name="nodelet_manager" default="slam_localization_nodelet_manager" />

  <node pkg="nodelet" type="nodelet" name="$(arg nodelet_manager)"
        args="manager" output="screen" />

  <!-- Global map server -->
  <node pkg="nodelet" type="nodelet" name="globalmap_server_nodelet"
        args="load hdl_localization/GlobalmapServerNodelet $(arg nodelet_manager)">
    <param name="globalmap_pcd"        value="$(arg map_pcd)" />
    <param name="convert_utm_to_local" value="false" />
    <param name="downsample_resolution" value="0.1" />
  </node>

  <!-- HDL Localization -->
  <node pkg="nodelet" type="nodelet" name="hdl_localization_nodelet"
        args="load hdl_localization/HdlLocalizationNodelet $(arg nodelet_manager)">
    <remap from="/velodyne_points"        to="$(arg points_topic)" />
    <remap from="/odom"                   to="/odom_3d" />
    <remap from="/gpsimu_driver/imu_data" to="$(arg imu_topic)" />

    <!-- Frame IDs -->
    <param name="odom_child_frame_id" value="$(arg odom_child_frame_id)" />

    <!-- IMU (rotation correction fix) -->
    <param name="use_imu"             value="$(arg use_imu)" />
    <param name="invert_acc"          value="false" />
    <param name="invert_gyro"         value="false" />
    <param name="cool_time_duration"  value="2.0" />

    <!-- Robot odometry prediction (position correction fix) -->
    <param name="enable_robot_odometry_prediction" value="true" />
    <param name="robot_odom_frame_id"              value="odom" />

    <!-- NDT: DIRECT7 is stable (vs DIRECT1 which is "unstable") -->
    <param name="reg_method"                  value="NDT_OMP" />
    <param name="ndt_neighbor_search_method"  value="DIRECT7" />
    <param name="ndt_neighbor_search_radius"  value="2.0" />
    <param name="ndt_resolution"              value="0.5" />   <!-- was 1.0 -->
    <param name="downsample_resolution"       value="0.1" />

    <!-- Initial pose (global localization overrides this) -->
    <param name="specify_init_pose" value="true" />
    <param name="init_pos_x"        value="0.0" />
    <param name="init_pos_y"        value="0.0" />
    <param name="init_pos_z"        value="0.0" />
    <param name="init_ori_w"        value="1.0" />
    <param name="init_ori_x"        value="0.0" />
    <param name="init_ori_y"        value="0.0" />
    <param name="init_ori_z"        value="0.0" />

    <param name="use_global_localization" value="$(arg use_global_localization)" />
  </node>
</launch>
