Panels:
  - Class: rviz/Displays
    Help Height: 0
    Name: Displays
    Property Tree Widget:
      Expanded: ~
      Splitter Ratio: 0.5
    Tree Height: 400
  - Class: rviz/Selection
    Name: Selection
  - Class: rviz/Tool Properties
    Expanded:
      - /2D Pose Estimate1
      - /2D Nav Goal1
    Name: Tool Properties
  - Class: rviz/Views
    Expanded:
      - /Current View1
    Name: Views
    Splitter Ratio: 0.5

Preferences:
  PromptSaveOnExit: true

Toolbars:
  toolButtonStyle: 2

Visualization Manager:
  Class: ""
  Displays:
    - Alpha: 0.5
      Axes Length: 1
      Axes Radius: 0.1
      Class: rviz/TF
      Enabled: true
      Frame Timeout: 15
      Name: TF
      Show Arrows: true
      Show Axes: true
      Show Names: false
      Marker Scale: 0.5
      Update Interval: 0
      Value: true

    - Alpha: 0.3
      Autocompute Intensity Bounds: true
      Class: rviz/PointCloud2
      Color: 255; 255; 255
      Color Transformer: FlatColor
      Enabled: true
      Name: Global Map
      Point Size: 1
      Position Transformer: XYZ
      Queue Size: 1
      Selectable: true
      Size (Pixels): 1
      Topic: /globalmap
      Value: true

    - Alpha: 1.0
      Autocompute Intensity Bounds: true
      Class: rviz/PointCloud2
      Color: 0; 255; 0
      Color Transformer: FlatColor
      Enabled: true
      Name: Filtered Scan
      Point Size: 2
      Position Transformer: XYZ
      Queue Size: 1
      Selectable: true
      Topic: /livox/lidar_filtered
      Value: true

    - Alpha: 0.8
      Autocompute Intensity Bounds: true
      Class: rviz/PointCloud2
      Color: 100; 100; 255
      Color Transformer: FlatColor
      Enabled: false
      Name: Raw Scan
      Point Size: 1
      Position Transformer: XYZ
      Queue Size: 1
      Selectable: true
      Topic: /rslidar_points
      Value: false

    - Alpha: 1
      Axes Length: 0.3
      Axes Radius: 0.05
      Class: rviz/Odometry
      Color: 255; 100; 0
      Enabled: true
      Keep: 50
      Name: HDL Pose (raw)
      Queue Size: 5
      Shape:
        Alpha: 0.5
        Color: 255; 100; 0
        Head Length: 0.1
        Head Radius: 0.05
        Shaft Length: 0.2
        Shaft Radius: 0.02
        Value: Arrow
      Topic: /odom_3d
      Value: true

    - Alpha: 1
      Axes Length: 0.3
      Axes Radius: 0.05
      Class: rviz/Odometry
      Color: 0; 255; 0
      Enabled: true
      Keep: 50
      Name: HDL Pose (corrected)
      Queue Size: 5
      Shape:
        Alpha: 0.5
        Color: 0; 255; 0
        Head Length: 0.1
        Head Radius: 0.05
        Shaft Length: 0.2
        Shaft Radius: 0.02
        Value: Arrow
      Topic: /odom_3d_corrected
      Value: true

    - Alpha: 1
      Axes Length: 0.5
      Axes Radius: 0.05
      Class: rviz/Odometry
      Color: 255; 0; 255
      Enabled: true
      Keep: 100
      Name: EKF Map
      Queue Size: 5
      Shape:
        Alpha: 0.5
        Color: 255; 0; 255
        Head Length: 0.15
        Head Radius: 0.07
        Shaft Length: 0.3
        Shaft Radius: 0.03
        Value: Arrow
      Topic: /odometry/filtered_map
      Value: true

  Enabled: true
  Global Options:
    Background Color: 48; 48; 48
    Default Light: true
    Fixed Frame: map
    Frame Rate: 25

  Name: root
  Tools:
    - Class: rviz/Interact
      Hide Inactive Icons: false
    - Class: rviz/MoveCamera
    - Class: rviz/Select
    - Class: rviz/FocusCamera
    - Class: rviz/Measure
    - Class: rviz/SetInitialPose
      Topic: /initialpose
    - Class: rviz/SetGoal
      Topic: /move_base_simple/goal
    - Class: rviz/PublishPoint
      Single click: true
      Topic: /clicked_point

  Value: true
  Views:
    Current:
      Class: rviz/TopDownOrtho
      Enable Stereo Rendering:
        Stereo Eye Separation: 0.06
        Stereo Focal Distance: 1
        Swap Stereo Eyes: false
        Value: false
      Invert Z Axis: false
      Name: Current View
      Near Clip Distance: 0.01
      Scale: 10
      Target Frame: <Fixed Frame>
      Value: TopDownOrtho (rviz)
      X: 0
      Y: 0
    Saved: ~

Window Geometry:
  Displays:
    collapsed: false
  Height: 1000
  Hide Left Dock: false
  Hide Right Dock: true
  QMainWindow State: 
  Selection:
    collapsed: false
  Tool Properties:
    collapsed: false
  Views:
    collapsed: false
  Width: 1400
  X: 0
  Y: 0
